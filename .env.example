# Email Alert Configuration
# Copy this to .env and FILL YOUR VALUES before running!

# Gmail SMTP (recommended - enable 2FA + App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password  # NOT regular password! Generate app pass.

# Recipient for alerts (can be same as sender or different)
ALERT_RECIPIENT=your-email@gmail.com

# Example for other providers:
# SMTP_HOST=smtp.outlook.com
# SMTP_PORT=587
# SMTP_USER=your@outlook.com

